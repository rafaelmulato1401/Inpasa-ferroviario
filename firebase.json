{
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  },
  "hosting": {
    "public": "../inpasa_deploy",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "storage.rules",
      "README.md",
      "netlify.toml"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "../inpasa_deploy/firestore.rules"
  },
  "storage": {
    "rules": "../inpasa_deploy/storage.rules"
  }
}
